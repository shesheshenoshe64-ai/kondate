          <div style={{ fontSize:"10px", letterSpacing:"4px", color:"#c4a882", marginBottom:"10px", textAlign:"center", fontWeight:"700" }}>HISTORY</div>
          <div style={{ display:"flex", flexDirection:"column", gap:"7px" }}>
            {history.slice(1).map((m, i) => {
              const c = categoryColors[m.category];
